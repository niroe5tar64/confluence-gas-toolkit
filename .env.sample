# build settings
MINIFY=false    # true | false
APP_ENV=dev     # dev | prod

# logging settings
LOG_LEVEL=INFO  # DEBUG | INFO | WARN | ERROR

# confluence settings
CONFLUENCE_PAT=<CONFLUENCE_PAT>         # Confluence Personal Access Token
CONFLUENCE_URL=https://confl.sample.com # ConfluenceのベースURL

# slack settings
# ジョブごとのSlack Webhook URL設定（必須）
# キーは SLACK_ROUTE (src/config/slack-routes.ts) で定義された値に対応
# 例: {"update-notify":"https://hooks.slack.com/...","update-summary":"https://hooks.slack.com/...","create-notify":"https://hooks.slack.com/..."}
SLACK_WEBHOOK_URLS={"update-notify":"<WEBHOOK_URL_1>","update-summary":"<WEBHOOK_URL_2>","create-notify":"<WEBHOOK_URL_3>"}
